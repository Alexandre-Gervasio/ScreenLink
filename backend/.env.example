# ScreenLink Backend Configuration

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# WebSocket
WS_PORT=3002
WS_HEARTBEAT_INTERVAL=30000

# Video Streaming
VIDEO_FPS=30
VIDEO_BITRATE=8000k
VIDEO_PRESET=ultrafast

# Link Sharing
LINK_EXPIRY_HOURS=24
LINK_CODE_LENGTH=6

# Logging
LOG_LEVEL=info
