{
  "name": "screenlink-backend",
  "version": "0.1.0",
  "type": "module",
  "description": "ScreenLink Backend - WebSocket Server + H.264 Streaming",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --loader ts-node/esm --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
