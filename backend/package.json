    "express-ws": "^5.0.2",
    "uuid": "^9.0.0",
    "dotenv": "^16.0.3",
    "ws": "^8.13.0",
    "screenshot-desktop": "^1.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
